[92]instructions = MINUS;
[93]instructions = MINUS;
[94]instructions = MINUS;
[95]instructions = MINUS;
[96]instructions = MINUS;
[97]instructions = MINUS;
[98]instructions = DOT;
[99]instructions = MINUS;
[100]instructions = MINUS;
[101]instructions = MINUS;
[102]instructions = MINUS;
[103]instructions = MINUS;
[104]instructions = MINUS;
[105]instructions = MINUS;
[106]instructions = MINUS;
[107]instructions = DOT;
iptr = 0;

memory[1024];
mptr = 0;

while iptr < len instructions {
    ins = [iptr]instructions;
    
    if ins < PLUS+0.5 {
        [mptr]memory = [mptr]memory + 1;
        if [mptr]memory > 255 { [mptr]memory = 0 };
    }
    else if ins < COMMA+0.5 {
        getc [mptr]memory;
    }
    else if ins < MINUS+0.5 {
        [mptr]memory = [mptr]memory - 1;
        if [mptr]memory < 0 { [mptr]memory = 255 };
    }
    else if ins < DOT+0.5 {
        putc [mptr]memory
    }
    else if ins < LEFT+0.5 {
        mptr = mptr - 1
    }
    else if ins < RIGHT+0.5 {
        mptr = mptr + 1
    }
    else if ins < OPAR+0.5 {
        if not [mptr]memory {
            depth = 0;
            done = 0;
            while not done {
                ins = [iptr]instructions;
                
                if not(ins - OPAR) { depth = depth + 1 };
                if not(ins - CPAR) { depth = depth - 1 };
                if not depth and not(ins - CPAR) { done = 1 };

                if not done { iptr = iptr + 1 }
            }
        }
    }
    else if ins < CPAR+0.5 {
        if [mptr]memory {
            depth = 0;
            done = 0;
            while not done {
                ins = [iptr]instructions;

                if not(ins - OPAR) { depth = depth - 1 };
                if not(ins - CPAR) { depth = depth + 1 };
                if not depth and not(ins - OPAR) { done = 1 };

                if not done { iptr = iptr - 1 }
            }
        }
    };

    iptr = iptr + 1
}