PLUS  = 43;
COMMA = 44;
MINUS = 45;
DOT   = 46;
LEFT  = 60;
RIGHT = 62;
OPAR  = 91;
CPAR  = 93;

instructions[108];
instructions[0] = PLUS;
instructions[1] = PLUS;
instructions[2] = PLUS;
