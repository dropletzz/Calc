instructions[90] = PLUS;
instructions[91] = DOT;
instructions[92] = MINUS;
instructions[93] = MINUS;
instructions[94] = MINUS;
instructions[95] = MINUS;
instructions[96] = MINUS;
instructions[97] = MINUS;
instructions[98] = DOT;
instructions[99] = MINUS;
instructions[100] = MINUS;
instructions[101] = MINUS;
instructions[102] = MINUS;
instructions[103] = MINUS;
instructions[104] = MINUS;
instructions[105] = MINUS;
instructions[106] = MINUS;
instructions[107] = DOT;
iptr = 0;

memory[1024];
mptr = 0;

while iptr < len instructions {
    ins = instructions[iptr];
    
    if ins == PLUS {
        memory[mptr] = (memory[mptr] + 1) % 256
    }
    else if ins == COMMA {
        getc memory[mptr]
    }
    else if ins == MINUS {
        memory[mptr] = (memory[mptr] - 1) % 256
    }
    else if ins == DOT {
        putc memory[mptr]
    }
    else if ins == LEFT {
        mptr = mptr - 1
    }
    else if ins == RIGHT {
        mptr = mptr + 1
    }
    else if ins == OPAR {
        if not memory[mptr] {
            depth = 0;
            done = 0;
            while not done {
                ins = instructions[iptr];

                if ins == OPAR { depth = depth + 1 };
                if ins == CPAR { depth = depth - 1 };
                if depth == 0 and ins == CPAR { done = 1 };

                if not done { iptr = iptr + 1 }
            }
        }
    }
    else if ins == CPAR {
        if memory[mptr] {
            depth = 0;
            done = 0;
            while not done {
                ins = instructions[iptr];

                if ins == OPAR { depth = depth - 1 };
                if ins == CPAR { depth = depth + 1 };
                if depth == 0 and ins == OPAR { done = 1 };

                if not done { iptr = iptr - 1 }
            }
        }
    };

    iptr = iptr + 1
}