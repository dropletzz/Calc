PLUS  = 43;
COMMA = 44;
MINUS = 45;
DOT   = 46;
LEFT  = 60;
RIGHT = 62;
OPAR  = 91;
CPAR  = 93;

instructions[108];
[0]instructions = PLUS;
[1]instructions = PLUS;
[2]instructions = PLUS;
[3]instructions = PLUS;
[4]instructions = PLUS;
[5]instructions = PLUS;
